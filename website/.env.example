# Platform API URLs
# AUTH_API_URL is for JWT verification only
MAHALAXMI_AUTH_API_URL=

# PLATFORM_API_URL is for checkout, server, and product operations
# Both currently point to the same server but are separate for future infra splits
MAHALAXMI_PLATFORM_API_URL=

# Activation API — server-side only, never in browser
MAHALAXMI_ACTIVATION_API_URL=

# PAK Keys — server-side only, never exposed to the browser
# mahalaxmi-headless-orchestration (Cloud Orchestration product)
MAHALAXMI_CLOUD_PAK_KEY=

# mahalaxmi-ai-terminal-orchestration (Terminal Orchestration product)
MAHALAXMI_TERMINAL_PAK_KEY=

# mahalaxmi-vscode-extension (VS Code Extension product)
MAHALAXMI_VSCODE_PAK_KEY=
